{
  "category": "images",
  "name": "Images & Media",
  "description": "High-quality images, photos, and media content - Free no-auth APIs",
  "prefix": "/images",
  "apis": [
    {
      "id": "dogceo",
      "name": "Dog CEO",
      "base_url": "https://dog.ceo/api",
      "auth_required": false,
      "endpoints": [
        {
          "path": "/images/dogceo/random",
          "method": "GET",
          "summary": "Get random dog image",
          "direct_url": "https://dog.ceo/api/breeds/image/random",
          "sample_request": "https://dog.ceo/api/breeds/image/random",
          "sample_response": {
            "message": "https://images.dog.ceo/breeds/terrier-american/n02093428_11085.jpg",
            "status": "success"
          }
        }
      ]
    },
    {
      "id": "cataas",
      "name": "Cat as a Service (CATAAS)",
      "base_url": "https://cataas.com",
      "auth_required": false,
      "endpoints": [
        {
          "path": "/images/cataas/random",
          "method": "GET",
          "summary": "Get random cat image",
          "direct_url": "https://cataas.com/cat?json=true",
          "sample_request": "https://cataas.com/cat?json=true",
          "sample_response": {
            "_id": "5e9c9f8f8e8f9c0001b8e8f9",
            "mimetype": "image/jpeg",
            "size": 45678,
            "tags": ["cute", "funny"],
            "url": "/cat/5e9c9f8f8e8f9c0001b8e8f9"
          }
        }
      ]
    },
    {
      "id": "picsum",
      "name": "Picsum (Lorem Picsum)",
      "base_url": "https://picsum.photos",
      "auth_required": false,
      "endpoints": [
        {
          "path": "/images/picsum",
          "method": "GET",
          "summary": "Get random placeholder image",
          "direct_url": "https://picsum.photos/{width}/{height}",
          "parameters": [
            {"name": "width", "type": "path", "default": 800, "description": "Image width"},
            {"name": "height", "type": "path", "default": 600, "description": "Image height"}
          ],
          "sample_request": "https://picsum.photos/800/600",
          "sample_response": "Returns image binary data",
          "note": "This endpoint returns actual image data, not JSON"
        }
      ]
    },
    {
      "id": "placekitten",
      "name": "PlaceKitten",
      "base_url": "https://placekitten.com",
      "auth_required": false,
      "endpoints": [
        {
          "path": "/images/placekitten",
          "method": "GET",
          "summary": "Get placeholder cat image",
          "direct_url": "https://placekitten.com/{width}/{height}",
          "parameters": [
            {"name": "width", "type": "path", "default": 800, "description": "Image width"},
            {"name": "height", "type": "path", "default": 600, "description": "Image height"}
          ],
          "sample_request": "https://placekitten.com/800/600",
          "sample_response": "Returns image binary data",
          "note": "Returns cute kitten placeholder images"
        }
      ]
    },
    {
      "id": "placedog",
      "name": "PlaceDog",
      "base_url": "https://placedog.net",
      "auth_required": false,
      "endpoints": [
        {
          "path": "/images/placedog",
          "method": "GET",
          "summary": "Get placeholder dog image",
          "direct_url": "https://placedog.net/{width}/{height}",
          "parameters": [
            {"name": "width", "type": "path", "default": 800, "description": "Image width"},
            {"name": "height", "type": "path", "default": 600, "description": "Image height"}
          ],
          "sample_request": "https://placedog.net/800/600",
          "sample_response": "Returns image binary data",
          "note": "Returns dog placeholder images"
        }
      ]
    },
    {
      "id": "placebear",
      "name": "PlaceBear",
      "base_url": "https://placebear.com",
      "auth_required": false,
      "endpoints": [
        {
          "path": "/images/placebear",
          "method": "GET",
          "summary": "Get placeholder bear image",
          "direct_url": "https://placebear.com/{width}/{height}",
          "parameters": [
            {"name": "width", "type": "path", "default": 800, "description": "Image width"},
            {"name": "height", "type": "path", "default": 600, "description": "Image height"}
          ],
          "sample_request": "https://placebear.com/800/600",
          "sample_response": "Returns image binary data",
          "note": "Returns bear placeholder images"
        }
      ]
    },
    {
      "id": "dummyimage",
      "name": "Dummy Image",
      "base_url": "https://dummyimage.com",
      "auth_required": false,
      "endpoints": [
        {
          "path": "/images/dummyimage",
          "method": "GET",
          "summary": "Get customizable placeholder image",
          "direct_url": "https://dummyimage.com/{width}x{height}/{bgcolor}/{fgcolor}",
          "parameters": [
            {"name": "width", "type": "path", "default": 800, "description": "Image width"},
            {"name": "height", "type": "path", "default": 600, "description": "Image height"},
            {"name": "bgcolor", "type": "path", "default": "cccccc", "description": "Background color (hex)"},
            {"name": "fgcolor", "type": "path", "default": "000000", "description": "Foreground/text color (hex)"}
          ],
          "sample_request": "https://dummyimage.com/800x600/cccccc/000000",
          "sample_response": "Returns image binary data",
          "note": "Customizable placeholder with text showing dimensions"
        }
      ]
    },
    {
      "id": "via_placeholder",
      "name": "Via Placeholder",
      "base_url": "https://via.placeholder.com",
      "auth_required": false,
      "endpoints": [
        {
          "path": "/images/via_placeholder",
          "method": "GET",
          "summary": "Get customizable placeholder image",
          "direct_url": "https://via.placeholder.com/{width}x{height}",
          "parameters": [
            {"name": "width", "type": "path", "default": 800, "description": "Image width"},
            {"name": "height", "type": "path", "default": 600, "description": "Image height"}
          ],
          "sample_request": "https://via.placeholder.com/800x600",
          "sample_response": "Returns image binary data",
          "note": "Simple placeholder images with dimensions as text"
        }
      ]
    }
  ],
  "use_cases": [
    "Get high-quality images without authentication",
    "Generate placeholder images",
    "Get random animal images",
    "Create customizable placeholders",
    "Get images for web development",
    "Access free photo content",
    "Create mockup images for prototyping"
  ]
}
    

