# Project Identity
PROJECT_ID=1
# PROJECT_PATH=/root/clawd-projects/123_my-scheduler  # Auto-detected if not set
BACKEND_URL=http://localhost:8002

# Channel: Telegram (requires TELEGRAM_BOT_TOKEN + TELEGRAM_CHAT_ID)
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# Channel: Discord (requires webhook URL)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Channel: Email (requires SMTP_* + EMAIL_TO)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# EMAIL_TO=recipient@gmail.com

# Channel: API (requires endpoint URL)
# API_ENDPOINT=https://example.com/webhook
