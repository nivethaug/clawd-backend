# PostgreSQL Configuration (PRODUCTION)
# This file is sourced by start-backend.sh

# Database connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dreampilot
DB_USER=admin
DB_PASSWORD=StrongAdminPass123

# Backend selection
USE_POSTGRES=true

# Optional: SQLite fallback (for rollback)
