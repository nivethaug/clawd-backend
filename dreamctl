            time.sleep(1)
        
        conn.close()
        
        print()
        print(f"📊 Summary:")
        print(f"   Repaired: {repaired}")
        print(f"   Failed: {failed}")
        print(f"   Skipped (OK): {skipped}")
        print()
        
        return 0 if failed == 0 else 1
        
    except Exception as e:
        print(f"\n❌ Error: {e}\n")
        logger.error(f"Bulk DNS repair failed: {e}")
        return 1


def main():
    parser = argparse.ArgumentParser(
        description="DreamPilot CLI - Infrastructure Management Tool",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  dreamctl repair-dns 657       Repair DNS for project 657
  dreamctl repair-all-dns       Repair DNS for all projects
  dreamctl verify 657           Verify project 657 deployment
  dreamctl list                 List all projects
  dreamctl status 657           Show project 657 status
"""
    )
    
    subparsers = parser.add_subparsers(dest="command", help="Command to run")
    
    # repair-dns command
    repair_parser = subparsers.add_parser("repair-dns", help="Repair DNS records for a project")
    repair_parser.add_argument("project_id", type=int, help="Project ID to repair DNS for")
    repair_parser.set_defaults(func=cmd_repair_dns)
    
    # repair-all-dns command
    repair_all_parser = subparsers.add_parser("repair-all-dns", help="Repair DNS for all projects")
    repair_all_parser.set_defaults(func=cmd_repair_all_dns)
    
    # verify command
    verify_parser = subparsers.add_parser("verify", help="Verify deployment status")
    verify_parser.add_argument("project_id", type=int, help="Project ID to verify")
    verify_parser.set_defaults(func=cmd_verify)
    
    # list command
    list_parser = subparsers.add_parser("list", help="List all projects")
    list_parser.set_defaults(func=cmd_list)
    
    # status command
    status_parser = subparsers.add_parser("status", help="Show project status")
    status_parser.add_argument("project_id", type=int, help="Project ID to show status for")
    status_parser.set_defaults(func=cmd_status)
    
    args = parser.parse_args()
    
    if args.command is None:
        parser.print_help()
        return 0
    
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
